rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    // Validation Blueprint for Handover
    function isValidHandover(data) {
      let requiredKeys = ['id', 'timestamp', 'outgoingName', 'projectName', 'ownerEmail', 'notes', 'status', 'actionItems', 'outgoingRole', 'incomingName', 'incomingEmail', 'location', 'shiftDateTime'];
      return data.keys().hasAll(requiredKeys) && data.keys().size() == requiredKeys.length
        && data.id is string && data.id.size() <= 128
        && data.projectName is string && data.projectName.size() <= 200
        && data.ownerEmail is string && data.ownerEmail.size() <= 128
        && data.status in ['routine', 'urgent', 'delay']
        && data.timestamp is string 
        && data.actionItems is list && data.actionItems.size() <= 50;
    }

    match /handovers/{handoverId} {
      allow read, write: if true;
    }
  }
}
